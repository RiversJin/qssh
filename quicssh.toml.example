# qssh configuration file

[client]
buffer_size = 16384
max_idle_timeout_ms = 60000
keepalive_interval_secs = 5
# Certificate verification: "none", "tofu", or path to CA cert
cert_verify = "tofu"
known_hosts = "~/.config/qssh/known_hosts"

[server]
listen = "0.0.0.0:4433"
proxy_to = "127.0.0.1:22"
buffer_size = 16384
max_idle_timeout_ms = 60000
keepalive_interval_secs = 5
cert_dir = "~/.config/qssh"

# SNI-based routing to different SSH servers
[server.routes]
# "host-a.example.com" = "10.0.0.1:22"
# "host-b.example.com" = "10.0.0.2:22"
